# ============================================================
# Ulogix — Suite Fontibon | configuracion de entorno
# Este archivo YA apunta a los servidores existentes del stack.
# Los secretos (Odoo, Google) van aqui y NUNCA en el codigo.
# ============================================================

# ---------- MQTT (broker existente del stack MES) ----------
MQTT_HOST=100.123.104.31
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_TOPIC_BASE=plant
MQTT_CLIENT_ID=ulogix-middleware
MQTT_QOS=1

# ---------- OPC UA (referencia; lo consumen Node-RED / Tecnomatix, ----------
# ---------- no este middleware: el puente a MQTT ya existe)         ----------
OPCUA_ENDPOINT=opc.tcp://100.123.104.31:62451

# ---------- Odoo (API externa XML-RPC) ----------
# Ajustes > Usuario > Seguridad de la cuenta > Nueva API key
ODOO_URL=https://ulogix-admin.odoo.com
ODOO_DB=ulogix-admin
ODOO_USER=ulogixteam@gmail.com
ODOO_API_KEY=36793ebc3101d9c6edf4d3b4100af97c85f7e58c
ODOO_COMPANY_ID=1

# ---------- Google Sheets (contabilidad) ----------
# JSON de cuenta de servicio + compartir el spreadsheet con su client_email
GOOGLE_SA_JSON=config/google_service_account.json
SHEETS_SPREADSHEET_ID=1R5Y7p3fOJI8JB0ze__H8Tu2hICYCgBTK-Jw_mjQEMr4

# ---------- Suite ----------
HORIZONTE_INICIO=2026-04
HORIZONTE_MESES=12
MC_N=10000
MC_N_INVENTARIO=300
SEMILLA=42
# true = fuerza dry-run aunque haya credenciales (util para demo)
DRY_RUN=false

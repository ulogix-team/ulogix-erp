# ============================================================
# Ulogix — Suite Fontibon | configuracion de entorno
# Plantilla PUBLICA — copia esto a .env y pon ahi tus valores reales.
# Los secretos (Odoo, Google, IPs internas) van SOLO en tu .env local
# (nunca versionado) y NUNCA en el codigo ni en archivos de ejemplo.
# ============================================================

# ---------- MQTT (broker del stack MES) ----------
MQTT_HOST=tu-ip-o-host-del-broker
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_TOPIC_BASE=plant
MQTT_CLIENT_ID=ulogix-middleware
MQTT_QOS=1

# ---------- OPC UA (referencia; lo consumen Node-RED / Tecnomatix, ----------
# ---------- no este middleware: el puente a MQTT ya existe)         ----------
OPCUA_ENDPOINT=opc.tcp://tu-ip-o-host:62451

# ---------- Odoo (API externa XML-RPC) ----------
# Ajustes > Usuario > Seguridad de la cuenta > Nueva API key
ODOO_URL=https://tu-instancia.odoo.com
ODOO_DB=tu-base-de-datos
ODOO_USER=tu-correo-de-login-odoo
ODOO_API_KEY=tu-api-key
ODOO_COMPANY_ID=1

# ---------- Google Sheets (contabilidad) ----------
# JSON de cuenta de servicio + compartir el spreadsheet con su client_email
GOOGLE_SA_JSON=config/google_service_account.json
SHEETS_SPREADSHEET_ID=tu-spreadsheet-id

# ---------- Suite ----------
HORIZONTE_INICIO=2026-04
HORIZONTE_MESES=12
MC_N=10000
MC_N_INVENTARIO=300
SEMILLA=42
# true = fuerza dry-run aunque haya credenciales (util para demo)
DRY_RUN=false
# true = Sheets/Odoo son obligatorios; no degrada silenciosamente a CSV/Excel/SQLite
EXTERNAL_ONLY=true
